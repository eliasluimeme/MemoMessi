generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String        @id @db.Uuid
  fullName       String        @map("full_name")
  phoneNumber    String?       @unique @map("phone_number")
  email          String        @unique
  role           Role          @default(USER)
  verified       Boolean       @default(false) @map("is_verified")
  telegramChatId String?       @unique @map("telegram_chat_id")
  image          String?       @map("avatar_url")
  createdAt      DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6) @map("created_at")
  updatedAt      DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6) @map("updated_at")
  favorites      Favorite[]
  subscriptions  Subscription?

  @@map("profiles")
}

model Signal {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pair            String
  market          String     @default("SPOT")
  action          String     @default("BUY")
  entryZone       Float      @map("entry_zone")
  stopLoss        Float?     @map("stop_loss")
  status          Status     @default(WITHIN_ENTRY_ZONE)
  note            String?
  imageURL        String?    @map("image_url")
  isClosed        Boolean?   @default(false) @map("is_closed")
  closedAt        DateTime?  @db.Timestamptz(6) @map("closed_at")
  createdAt       DateTime   @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt       DateTime   @default(now()) @db.Timestamptz(6) @map("updated_at")
  contractAddress String?    @map("contract_address")
  network         String?    @default("solana")
  isVip           Boolean    @default(false) @map("is_vip")
  favorites       Favorite[]
  targets         Target[]

  @@map("signals")
}

model Target {
  id       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  number   Int
  price    Float
  hit      Boolean   @default(false)
  hitAt    DateTime? @db.Timestamptz(6) @map("hit_at")
  gain     Float     @default(0)
  signalId String    @db.Uuid @map("signal_id")
  signal   Signal    @relation(fields: [signalId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("targets")
}

model Subscription {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String             @unique @db.Uuid @map("user_id")
  status    SubscriptionStatus @default(PENDING)
  plan      Plan               @default(ONE_MONTH)
  startDate DateTime           @default(now()) @db.Timestamptz(6) @map("start_date")
  expiresAt DateTime           @db.Timestamptz(6) @map("expires_at")
  createdAt DateTime           @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt DateTime           @default(now()) @db.Timestamptz(6) @map("updated_at")
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("subscriptions")
}

model Favorite {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  signalId  String   @db.Uuid @map("signal_id")
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  signal    Signal   @relation(fields: [signalId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, signalId])
  @@map("favorites")
}

enum Role {
  ADMIN
  USER
  PRIVATE

  @@map("user_role")
}

enum Status {
  WITHIN_ENTRY_ZONE
  TP1
  TP2
  TP3
  TP4
  TP5
  TP6
  TP7
  TP8
  TP9
  TP10
  CLOSED

  @@map("signal_status")
}

enum Plan {
  ONE_MONTH
  THREE_MONTHS
  SIX_MONTHS
  ONE_YEAR

  @@map("subscription_plan")
}

enum SubscriptionStatus {
  ACTIVE
  PENDING
  EXPIRED
  SUSPENDED
  PRIVATE

  @@map("subscription_status")
}
